// ═══════════════════════ MENU SCREEN ═══════════════════════
function MenuScreen({cartItems,onAdd,onDone}){
  const [cat,setCat]   = useState("Pizza");
  const [qtys,setQtys] = useState({});
  const [sups,setSups] = useState({});
  const [ok,setOk]     = useState({});
  const C = MENU[cat];
  const cartCount = cartItems.reduce((s,i)=>s+i.qty,0);
  const cartTotal = cartItems.reduce((s,i)=>s+i.price*i.qty,0);
  const qty = id=>qtys[id]||0;
  const bump = (id,d)=>setQtys(p=>({...p,[id]:Math.max(0,(p[id]||0)+d)}));
  const toggleSup = (iid,sup)=>setSups(p=>{const cur=p[iid]||[];return{...p,[iid]:cur.find(s=>s.id===sup.id)?cur.filter(s=>s.id!==sup.id):[...cur,sup]};});
  const add = item=>{
    const q=qty(item.id);if(!q)return;
    const is=sups[item.id]||[];const se=is.reduce((s,x)=>s+x.price,0);
    onAdd({...item,category:cat,qty:q,supplements:is.map(s=>s.name),price:item.price+se});
    setOk(p=>({...p,[item.id]:true}));
    setTimeout(()=>setOk(p=>({...p,[item.id]:false})),700);
    setQtys(p=>({...p,[item.id]:0}));setSups(p=>({...p,[item.id]:[]}));
  };
  return(
    <div style={{background:"#f8fafc",minHeight:"100vh",maxWidth:480,margin:"0 auto",display:"flex",flexDirection:"column"}}>
      <div style={{background:"#fff",borderBottom:"1px solid #e5e7eb",padding:"12px 16px",position:"sticky",top:0,zIndex:20}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}}>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontWeight:900,fontSize:17,color:"#111"}}>Menu</span>
            {cartCount>0&&<span style={{background:"#16a34a",color:"#fff",borderRadius:20,padding:"2px 10px",fontSize:12,fontWeight:800}}>🛒 {cartCount} article{cartCount>1?"s":""}</span>}
          </div>
          <button onClick={onDone} style={{background:"#111",color:"#fff",border:"none",borderRadius:10,padding:"9px 18px",fontWeight:800,fontSize:13,cursor:"pointer"}}>
            Voir commande {cartCount>0&&`· ${DA(cartTotal)}`}
          </button>
        </div>
        <div style={{display:"flex",gap:6,overflowX:"auto",scrollbarWidth:"none",paddingBottom:2}}>
          {Object.entries(MENU).map(([name,data])=>(
            <button key={name} onClick={()=>{setCat(name);setQtys({});setSups({});setOk({});}}
              style={{whiteSpace:"nowrap",padding:"7px 14px",borderRadius:20,fontSize:13,fontWeight:700,cursor:"pointer",border:"none",flexShrink:0,
                background:cat===name?MENU[cat].color:"#f3f4f6",color:cat===name?"#fff":"#374151"}}>
              {data.emoji} {name}
            </button>
          ))}
        </div>
      </div>
      <div style={{flex:1,overflowY:"auto",padding:"12px 16px 32px",display:"flex",flexDirection:"column",gap:10}}>
        {C.items.map(item=>{
          const q=qty(item.id),is=sups[item.id]||[],se=is.reduce((s,x)=>s+x.price,0),fl=ok[item.id];
          return(
            <div key={item.id} style={{borderRadius:14,overflow:"hidden",border:`2px solid ${fl?"#16a34a":q>0?C.color:"#e5e7eb"}`,background:fl?"#f0fdf4":q>0?C.color+"12":"#fff",transition:"border-color .18s,background .18s"}}>
              <div style={{display:"flex",alignItems:"center",gap:8,padding:"13px 12px"}}>
                <div style={{flex:1,minWidth:0}}>
                  <div style={{fontWeight:700,fontSize:14,color:"#111"}}>{item.name}</div>
                  {item.desc&&<div style={{fontSize:11,color:"#9ca3af",marginTop:2,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{item.desc}</div>}
                  {is.length>0&&<div style={{fontSize:10,color:"#059669",fontWeight:600,marginTop:2}}>+ {is.map(s=>s.name).join(", ")}</div>}
                </div>
                <div style={{fontWeight:800,fontSize:13,color:C.color,flexShrink:0,whiteSpace:"nowrap"}}>{DA(item.price+se)}</div>
                <div style={{display:"flex",alignItems:"center",gap:4,flexShrink:0}}>
                  {q>0&&<button onClick={()=>bump(item.id,-1)} style={{width:32,height:32,borderRadius:8,border:`2px solid ${C.color}`,background:"#fff",color:C.color,fontWeight:900,fontSize:20,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",padding:0}}>−</button>}
                  {q>0&&<span style={{fontWeight:900,fontSize:16,minWidth:22,textAlign:"center",color:"#111"}}>{q}</span>}
                  <button onClick={()=>bump(item.id,1)} style={{width:32,height:32,borderRadius:8,border:"none",background:C.color,color:"#fff",fontWeight:900,fontSize:20,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",padding:0}}>+</button>
                </div>
                {q>0&&<button onClick={()=>add(item)} style={{flexShrink:0,border:"none",borderRadius:9,padding:"9px 12px",fontWeight:800,fontSize:12,cursor:"pointer",whiteSpace:"nowrap",transition:"background .18s",background:fl?"#16a34a":"#111",color:"#fff"}}>{fl?"✓ Ajouté !":"✓ Ajouter"}</button>}
              </div>
              {q>0&&C.supplements.length>0&&(
                <div style={{borderTop:`1.5px solid ${C.color}30`,padding:"10px 12px 13px",background:"#fafafa"}}>
                  <div style={{fontSize:10,fontWeight:700,color:"#9ca3af",letterSpacing:1,textTransform:"uppercase",marginBottom:8}}>Suppléments</div>
                  <div style={{display:"flex",flexWrap:"wrap",gap:7}}>
                    {C.supplements.map(sup=>{const act=is.find(s=>s.id===sup.id);return(
                      <button key={sup.id} onClick={()=>toggleSup(item.id,sup)}
                        style={{padding:"7px 13px",borderRadius:9,fontSize:12,fontWeight:600,cursor:"pointer",transition:"all .15s",border:`1.5px solid ${act?C.color:"#e5e7eb"}`,background:act?C.color:"#fff",color:act?"#fff":"#374151"}}>
                        {sup.name} <span style={{opacity:.7}}>+{DA(sup.price)}</span>
                      </button>
                    );})}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

