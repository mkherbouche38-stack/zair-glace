// ═══════════════════════ ÉCRAN TABLE ═══════════════════════
function TableScreen({table,order,onBack,onUpdate,onSend}){
  const [showTicket,setShowTicket]=useState(null);
  const [note,setNote]=useState(order?.note||"");
  const [inMenu,setInMenu]=useState(false);
  const items=order?.items||[];
  const total=items.reduce((s,i)=>s+i.price*i.qty,0);
  const count=items.reduce((s,i)=>s+i.qty,0);
  const catColors=Object.fromEntries(Object.entries(MENU).map(([k,v])=>[k,v.color]));
  const addItem=item=>{
    const ex=items.find(i=>i.id===item.id&&JSON.stringify(i.supplements)===JSON.stringify(item.supplements));
    const next=ex?items.map(i=>i.id===item.id&&JSON.stringify(i.supplements)===JSON.stringify(item.supplements)?{...i,qty:i.qty+item.qty}:i):[...items,item];
    onUpdate(table,{items:next,note,total:next.reduce((s,i)=>s+i.price*i.qty,0)});
  };
  const removeItem=idx=>{const next=items.filter((_,i)=>i!==idx);onUpdate(table,{items:next,note,total:next.reduce((s,i)=>s+i.price*i.qty,0)});};
  const changeQty=(idx,d)=>{const next=items.map((item,i)=>i===idx?{...item,qty:Math.max(1,item.qty+d)}:item);onUpdate(table,{items:next,note,total:next.reduce((s,i)=>s+i.price*i.qty,0)});};
  const handleSend=()=>{const o={id:orderCounter++,items,total,note};onSend(table,o);setShowTicket(o);setNote("");};
  if(inMenu) return <MenuScreen cartItems={items} onAdd={addItem} onDone={()=>setInMenu(false)}/>;
  return(
    <div style={{background:"#f8fafc",minHeight:"100vh",maxWidth:480,margin:"0 auto",display:"flex",flexDirection:"column"}}>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",padding:"14px 12px 14px 8px",background:"#fff",borderBottom:"1px solid #e5e7eb",position:"sticky",top:0,zIndex:10}}>
        <button onClick={onBack} style={{background:"none",border:"none",fontSize:22,cursor:"pointer",color:"#374151",padding:"0 4px"}}>←</button>
        <div style={{textAlign:"center"}}>
          <div style={{fontWeight:900,fontSize:18,color:"#111"}}>Table {table}</div>
          <div style={{fontSize:11,color:"#9ca3af"}}>{count} article{count!==1?"s":""}</div>
        </div>
        <div style={{fontWeight:900,fontSize:17,color:"#e85d04"}}>{DA(total)}</div>
      </div>
      <div style={{flex:1,overflowY:"auto",padding:"12px 16px"}}>
        {items.length===0?(
          <div style={{textAlign:"center",padding:"60px 20px",color:"#d1d5db"}}>
            <div style={{fontSize:52,marginBottom:12}}>🍽️</div>
            <div style={{fontSize:16,fontWeight:700}}>Commande vide</div>
            <div style={{fontSize:13,marginTop:4}}>Appuyez sur "+ Ajouter un article"</div>
          </div>
        ):items.map((item,idx)=>(
          <div key={idx} style={{background:"#fff",borderRadius:12,padding:"12px 14px",marginBottom:10,boxShadow:"0 1px 4px rgba(0,0,0,.06)",display:"flex",alignItems:"flex-start",gap:10}}>
            <div style={{width:8,height:8,borderRadius:"50%",background:catColors[item.category]||"#ccc",marginTop:6,flexShrink:0}}/>
            <div style={{flex:1,minWidth:0}}>
              <div style={{fontWeight:700,fontSize:14,color:"#111"}}>{item.name}</div>
              <div style={{fontSize:11,color:"#9ca3af"}}>{item.category}</div>
              {item.supplements?.length>0&&<div style={{fontSize:11,color:"#059669",marginTop:2}}>+ {item.supplements.join(", ")}</div>}
            </div>
            <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:6}}>
              <div style={{fontWeight:800,fontSize:14,color:catColors[item.category]||"#111"}}>{DA(item.price*item.qty)}</div>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                <button onClick={()=>changeQty(idx,-1)} style={{width:28,height:28,borderRadius:7,border:"1.5px solid #e5e7eb",background:"#f9fafb",cursor:"pointer",fontWeight:800,fontSize:16,display:"flex",alignItems:"center",justifyContent:"center",padding:0}}>−</button>
                <span style={{fontWeight:800,minWidth:18,textAlign:"center"}}>{item.qty}</span>
                <button onClick={()=>changeQty(idx,1)} style={{width:28,height:28,borderRadius:7,border:"1.5px solid #e5e7eb",background:"#f9fafb",cursor:"pointer",fontWeight:800,fontSize:16,display:"flex",alignItems:"center",justifyContent:"center",padding:0}}>+</button>
                <button onClick={()=>removeItem(idx)} style={{color:"#ef4444",background:"none",border:"none",cursor:"pointer",fontSize:16,padding:0}}>🗑</button>
              </div>
            </div>
          </div>
        ))}
        <textarea value={note} onChange={e=>{setNote(e.target.value);onUpdate(table,{items,note:e.target.value,total});}}
          placeholder="📝 Note pour la cuisine..." rows={2}
          style={{width:"100%",padding:"10px 12px",borderRadius:10,border:"1.5px solid #e5e7eb",fontSize:13,resize:"none",boxSizing:"border-box",outline:"none",marginTop:8}}/>
      </div>
      <div style={{padding:"12px 16px",borderTop:"1px solid #e5e7eb",background:"#fff"}}>
        <button onClick={()=>setInMenu(true)} style={{width:"100%",padding:"14px",borderRadius:12,border:"2px dashed #e5e7eb",background:"#f9fafb",color:"#374151",fontSize:15,fontWeight:700,cursor:"pointer",marginBottom:items.length>0?10:0}}>
          ＋ Ajouter un article
        </button>
        {items.length>0&&(
          <div style={{background:"#111",borderRadius:12,padding:"14px 16px",display:"flex",justifyContent:"space-between",alignItems:"center"}}>
            <div>
              <div style={{fontSize:11,color:"#9ca3af"}}>Total commande</div>
              <div style={{fontWeight:900,fontSize:20,color:"#e85d04"}}>{DA(total)}</div>
            </div>
            <button onClick={handleSend} style={{background:"#e85d04",color:"#fff",border:"none",borderRadius:10,padding:"12px 22px",fontWeight:800,fontSize:15,cursor:"pointer"}}>🍴 Envoyer cuisine</button>
          </div>
        )}
      </div>
      {showTicket&&<KitchenTicket table={table} order={showTicket} onClose={()=>setShowTicket(null)}/>}
    </div>
  );
}

// ═══════════════════════ APP ═══════════════════════
function App(){
  const [unlocked,setUnlocked]=useState(false);
  const [screen,setScreen]=useState("tables");
  const [activeTable,setActive]=useState(null);
  const [orders,setOrders]=useState({});
  const [sentOrders,setSent]=useState({});
  if(!unlocked) return <PinScreen onUnlock={()=>setUnlocked(true)}/>;
  const updateOrder=(t,data)=>setOrders(p=>({...p,[t]:data}));
  const sendKitchen=(t,order)=>{setSent(p=>({...p,[t]:[...(p[t]||[]),order]}));setOrders(p=>({...p,[t]:{items:[],note:"",total:0}}));};
  if(screen==="table") return <TableScreen table={activeTable} order={orders[activeTable]} onBack={()=>setScreen("tables")} onUpdate={updateOrder} onSend={sendKitchen}/>;
  const dayTotal=Object.values(sentOrders).flat().reduce((s,o)=>s+o.total,0);
  return(
    <div style={{background:"#f8fafc",minHeight:"100vh",maxWidth:480,margin:"0 auto"}}>
      <div style={{background:"#111",padding:"20px 20px 16px"}}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-end"}}>
          <div>
            <div style={{fontSize:11,color:"#9ca3af",letterSpacing:2,textTransform:"uppercase",fontWeight:600}}>Le goût qui te régale</div>
            <div style={{fontSize:26,fontWeight:900,color:"#fff",lineHeight:1.1}}>ZAIR GLACE</div>
            <div style={{fontSize:11,color:"#e85d04",fontWeight:600,marginTop:2}}>🍕 GLACE · FOOD · CRÊPE · FAIT MAISON</div>
          </div>
          <div style={{textAlign:"right"}}>
            <div style={{fontSize:11,color:"#6b7280"}}>Recette du jour</div>
            <div style={{fontSize:18,fontWeight:900,color:"#e85d04"}}>{DA(dayTotal)}</div>
            <button onClick={()=>setUnlocked(false)} style={{marginTop:6,fontSize:11,color:"#6b7280",background:"none",border:"none",cursor:"pointer"}}>🔒 Verrouiller</button>
          </div>
        </div>
      </div>
      <div style={{padding:16}}>
        <div style={{fontSize:12,fontWeight:700,color:"#9ca3af",letterSpacing:1,textTransform:"uppercase",marginBottom:12}}>Sélectionner une table</div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:12}}>
          {TABLES.map(t=>{
            const o=orders[t],s=sentOrders[t],has=o?.items?.length>0,sent=s?.length>0;
            return(
              <button key={t} onClick={()=>{setActive(t);setScreen("table");}}
                style={{borderRadius:16,padding:"18px 10px",cursor:"pointer",textAlign:"center",outline:"none",border:`2px solid ${has?"#e85d04":sent?"#d1fae5":"#e5e7eb"}`,background:has?"#fff7ed":sent?"#f0fdf4":"#fff"}}>
                <div style={{fontSize:28,marginBottom:4}}>{has?"🔴":sent?"✅":"⬜"}</div>
                <div style={{fontWeight:900,fontSize:18,color:"#111"}}>Table {t}</div>
                {has&&<div style={{fontSize:11,color:"#e85d04",fontWeight:700,marginTop:3}}>En cours — {DA(o.total)}</div>}
                {!has&&sent&&<div style={{fontSize:11,color:"#059669",fontWeight:700,marginTop:3}}>{s.length} envoyée{s.length>1?"s":""}</div>}
                {!has&&!sent&&<div style={{fontSize:11,color:"#d1d5db",marginTop:3}}>Libre</div>}
              </button>
            );
          })}
        </div>
        <div style={{display:"flex",gap:16,marginTop:20,padding:"12px 14px",background:"#f9fafb",borderRadius:12}}>
          <span style={{fontSize:12,color:"#6b7280"}}>🔴 En cours</span>
          <span style={{fontSize:12,color:"#6b7280"}}>✅ Envoyé cuisine</span>
          <span style={{fontSize:12,color:"#6b7280"}}>⬜ Libre</span>
        </div>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>