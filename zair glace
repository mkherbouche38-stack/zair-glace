// ═══════════════════════ PIN ═══════════════════════
function PinScreen({ onUnlock }) {
  const [pin,setPin]     = useState("");
  const [error,setError] = useState(false);
  const [shake,setShake] = useState(false);

  const press = (val) => {
    if (pin.length >= 4) return;
    const next = pin + val;
    setPin(next);
    setError(false);
    if (next.length === 4) {
      if (next === SECRET_PIN) {
        setTimeout(() => onUnlock(), 180);
      } else {
        setTimeout(() => {
          setShake(true); setError(true);
          setTimeout(() => { setPin(""); setShake(false); }, 700);
        }, 120);
      }
    }
  };
  const del = () => { setPin(p => p.slice(0,-1)); setError(false); };
  const KEYS = [["1","2","3"],["4","5","6"],["7","8","9"],["","0","⌫"]];

  return (
    <div style={{background:"#111",minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:24}}>
      <div style={{textAlign:"center",marginBottom:40}}>
        <div style={{fontSize:40,marginBottom:8}}>🍴</div>
        <div style={{fontSize:28,fontWeight:900,color:"#fff",letterSpacing:1}}>ZAIR GLACE</div>
        <div style={{fontSize:12,color:"#6b7280",marginTop:4,letterSpacing:2,textTransform:"uppercase"}}>Espace serveur</div>
      </div>
      <div style={{display:"flex",gap:16,marginBottom:36,animation:shake?"shake .5s ease":"none"}}>
        {[0,1,2,3].map(i=>(
          <div key={i} style={{width:18,height:18,borderRadius:"50%",
            background:pin.length>i?(error?"#ef4444":"#e85d04"):"transparent",
            border:`2px solid ${error?"#ef4444":pin.length>i?"#e85d04":"#444"}`,
            transition:"background .15s,border-color .15s"}}/>
        ))}
      </div>
      {error&&<div style={{color:"#ef4444",fontSize:13,fontWeight:600,marginBottom:20,marginTop:-20}}>Code incorrect</div>}
      <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:12,width:"100%",maxWidth:280}}>
        {KEYS.flat().map((k,i)=>{
          if(k==="") return <div key={i}/>;
          return(
            <button key={i} onClick={()=>k==="⌫"?del():press(k)}
              style={{height:68,borderRadius:16,fontSize:k==="⌫"?22:26,fontWeight:700,cursor:"pointer",border:"none",
                background:k==="⌫"?"#1f1f1f":"#1a1a1a",color:k==="⌫"?"#9ca3af":"#fff"}}
              onPointerDown={e=>e.currentTarget.style.background="#2a2a2a"}
              onPointerUp={e=>e.currentTarget.style.background=k==="⌫"?"#1f1f1f":"#1a1a1a"}>
              {k}
            </button>
          );
        })}
      </div>
    </div>
  );
}

